      "flow": "4.0",
      "pressure": "1.0",
      "exit": {
        "type": "pressure",
        "condition": "over",
        "value": "4.0"
      }
    },
    {
      "name": "pause",
      "pump": "flow",
      "transition": "fast",
      "temperature": "90.0",
      "sensor": "coffee",
