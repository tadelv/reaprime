      "pressure": "4.0"
    },
    {
      "name": "flat flow",
      "pump": "flow",
      "transition": "fast",
      "temperature": "92.0",
      "sensor": "coffee",
      "seconds": "20.0",
      "volume": "100.0",
      "weight": "0.0",
      "flow": "2.2",
      "pressure": "4.0"
    },
    {
      "name": "reset temperature",
      "pump": "flow",
      "transition": "fast",
      "temperature": "98.0",
      "sensor": "coffee",
      "seconds": "1.0",
      "volume": "100.0",
      "weight": "0.0",
      "flow": "0.0",
      "pressure": "4.0"
    }
  ],
  "tank_temperature": "0.0",
  "target_weight": "60.0",
