      "pump": "pressure",
      "transition": "fast",
      "temperature": "89.0",
      "sensor": "coffee",
      "seconds": "2.0",
      "volume": "100.0",
      "weight": "0.0",
      "pressure": "2.0",
      "flow": "8.0",
      "limiter": {
        "value": "0.0",
        "range": "0.6"
      }
    },
    {
